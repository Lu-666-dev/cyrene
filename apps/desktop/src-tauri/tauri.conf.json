{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cyrene",
  "version": "0.1.0",
  "identifier": "com.cyrene.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../model-lab -- --strictPort",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build --prefix ../model-lab",
    "frontendDist": "../../model-lab/dist"
  },
  "app": {
    "windows": [
      {
        "label": "pet",
        "title": "Cyrene",
        "url": "pet.html",
        "width": 800,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "focus": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
